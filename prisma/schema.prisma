generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile               UserProfile?
  notebooks             Notebook[]
  solutions             Solution[]
  subscriptions         Subscription[]
  debateRounds          DebateRound[]
  innovationValidations InnovationValidation[]
  brainRuns             BrainRun[]
  agentMemories         AgentMemory[]
}

model UserProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  companyType     String?
  preferredThemes String[]
  trlInterest     Int?
  writingProfile  WritingProfile @default(ACADEMICO_FORMAL)
  lensApiToken    String?        @db.Text
  serpApiKey      String?        @db.Text
  user            User           @relation(fields: [userId], references: [id])
}

model Solution {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  trl         Int?
  benefits    String[]
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Notebook {
  id        String   @id @default(cuid())
  title     String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id])
  document              Document?
  sources               SourceFile[]
  tasks                 Task[]
  debateRounds          DebateRound[]
  snapshots             DocumentSnapshot[]
  innovationValidations InnovationValidation[]
  brainRuns             BrainRun[]
  agentMemories         AgentMemory[]
}

model Document {
  id         String   @id @default(cuid())
  notebookId String   @unique
  content    Json
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt

  notebook  Notebook           @relation(fields: [notebookId], references: [id])
  snapshots DocumentSnapshot[]
}

model SourceFile {
  id         String   @id @default(cuid())
  notebookId String
  name       String
  mimeType   String
  url        String
  size       Int
  uploadedAt DateTime @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  notebookId  String
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id])
}

model Edital {
  id                  String    @id @default(cuid())
  nome                String
  orgao               String
  tipoInstrumento     String
  abrangencia         String
  uf                  String?
  temas               String[]
  status              String // aberto, fechado, fluxo_contínuo
  dataAbertura        DateTime?
  dataFechamento      DateTime?
  valorMin            Float?
  valorMax            Float?
  contrapartida       String?
  prazoExecucao       String?
  trlEntrada          Int?
  trlSaida            Int?
  linkPaginaOficial   String?
  linkInscricaoDireta String?
  resumo              String?
  criteriosAvaliacao  Json?
  documentosChecklist Json?
  passoAPasso         Json?
  errosComuns         Json?
  requerValidacao     Boolean   @default(false)
  ultimaAtualizacao   DateTime  @default(now())
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String
  status           String
  plan             String
  stripeSubId      String?   @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
}

enum WritingProfile {
  ACADEMICO_FORMAL
  TECNICO_APLICADO
  INSTITUCIONAL_PUBLICO
}

enum AgentType {
  GEMINI_SEARCH  // Google Gemini + Search Grounding — Auditor Web
  GEMINI_CREATE  // Google Gemini puro — Pesquisador Criativo
  DEEPSEEK       // DeepSeek — Analista Quantitativo
  LLAMA          // Groq/Llama — Revisor Ultra-Rápido
  WATSONX_BR     // IBM WatsonX — Árbitro de Compliance BR
}

enum DebateMode {
  CONSENSUS
  DEVILS_ADVOCATE
  STRESS_TEST
  COMPLIANCE_ONLY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─── AI Features ──────────────────────────────────────────────────────────────

model DebateRound {
  id         String     @id @default(cuid())
  createdAt  DateTime   @default(now())
  notebookId String
  userId     String
  mode       DebateMode
  title      String?

  notebook Notebook        @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages DebateMessage[]

  @@index([notebookId])
  @@index([userId])
}

model DebateMessage {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  debateRoundId String
  agentType     AgentType
  content       String    @db.Text
  round         Int

  debateRound DebateRound @relation(fields: [debateRoundId], references: [id], onDelete: Cascade)

  @@index([debateRoundId])
}

model DocumentSnapshot {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  notebookId String
  documentId String
  content    Json
  label      String?
  version    Int

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@index([documentId])
}

model InnovationValidation {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  notebookId String
  userId     String
  query      String   @db.Text
  result     Json
  score      Float?

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@index([userId])
}

model BrainRun {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  notebookId String
  userId     String
  prompt     String   @db.Text
  status     String   @default("pending")

  notebook Notebook    @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes    BrainNode[]

  @@index([notebookId])
  @@index([userId])
}

model BrainNode {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  brainRunId   String
  nodeType     String
  content      Json
  parentNodeId String?
  order        Int

  brainRun BrainRun @relation(fields: [brainRunId], references: [id], onDelete: Cascade)

  @@index([brainRunId])
  @@index([parentNodeId])
}

model AgentMemory {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  notebookId String?
  agentType  AgentType
  key        String
  value      String    @db.Text

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([userId, agentType, key])
  @@index([userId])
  @@index([notebookId])
}
