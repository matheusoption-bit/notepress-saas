generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  notebooks     Notebook[]
  solutions     Solution[]
  subscriptions Subscription[]
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyType    String?
  preferredThemes String[]
  trlInterest    Int?
  writingProfile WritingProfile @default(ACADEMICO_FORMAL)
  user           User     @relation(fields: [userId], references: [id])
}

model Solution {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  trl         Int?
  benefits    String[]
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Notebook {
  id        String   @id @default(cuid())
  title     String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  document  Document?
  sources   SourceFile[]
  tasks     Task[]
}

model Document {
  id         String   @id @default(cuid())
  notebookId String   @unique
  content    Json
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt

  notebook   Notebook @relation(fields: [notebookId], references: [id])
}

model SourceFile {
  id         String   @id @default(cuid())
  notebookId String
  name       String
  mimeType   String
  url        String
  size       Int
  uploadedAt DateTime @default(now())

  notebook   Notebook @relation(fields: [notebookId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  notebookId  String
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())

  notebook    Notebook   @relation(fields: [notebookId], references: [id])
}

model Edital {
  id                    String   @id @default(cuid())
  nome                  String
  orgao                 String
  tipoInstrumento       String
  abrangencia           String
  uf                    String?
  temas                 String[]
  status                String   // aberto, fechado, fluxo_contínuo
  dataAbertura          DateTime?
  dataFechamento        DateTime?
  valorMin              Float?
  valorMax              Float?
  contrapartida         String?
  prazoExecucao         String?
  trlEntrada            Int?
  trlSaida              Int?
  linkPaginaOficial     String?
  linkInscricaoDireta   String?
  resumo                String?
  criteriosAvaliacao    Json?
  documentosChecklist   Json?
  passoAPasso           Json?
  errosComuns           Json?
  requerValidacao       Boolean  @default(false)
  ultimaAtualizacao     DateTime @default(now())
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  status          String
  plan            String
  stripeSubId     String?  @unique
  currentPeriodEnd DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

enum WritingProfile {
  ACADEMICO_FORMAL
  TECNICO_APLICADO
  INSTITUCIONAL_PUBLICO
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
